# Use official Node.js image
FROM node:18-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy source code
COPY . .

# Build for production
RUN npm run build

# Install serve to run the build
RUN npm install -g serve

EXPOSE 3000

# Start server
CMD ["serve", "-s", "dist", "-l", "3000"]
